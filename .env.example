# ──────────────────────────────────────────────────────────
# Synatyx Context Engine — Environment Variables
# cp .env.example .env  and fill in your values
# ──────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# Run mode: mcp (stdio, default) | graphql (FastAPI+SSE) | both
RUN_MODE=mcp

# Server — only used in graphql / both mode
HOST=0.0.0.0
PORT=8000

# ── Auth (HTTP/SSE transport) ─────────────────────────────
# Admin API key for the MCP HTTP/SSE server. Leave empty to disable auth
# (every request allowed). When set, clients must send this key either in the
# AUTH_HEADER_NAME header or as "Authorization: Bearer <key>".
AUTH_ADMIN_KEY=
# Header clients send the key in (default: X-Auth-Key)
AUTH_HEADER_NAME=X-Auth-Key

# ── Qdrant ────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=ctx_default
QDRANT_VECTOR_SIZE=1536

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_L1_MAX_MESSAGES=20

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_DSN=postgresql+asyncpg://context_engine:context_engine@localhost:5432/context_engine

# ── Embeddings ────────────────────────────────────────────
# Provider: "openai" (recommended) | "sentence-transformers" (local, free)
EMBEDDING_PROVIDER=openai
# Embedding model — works for any provider:
#   openai: text-embedding-3-small | text-embedding-3-large | text-embedding-ada-002
#   sentence-transformers: all-MiniLM-L6-v2 | all-mpnet-base-v2
EMBEDDING_MODEL=text-embedding-3-small
# Required for openai provider (also used for LLM summarization)
EMBEDDING_OPENAI_API_KEY=sk-...

# ── LLM (summarization) ───────────────────────────────────
# Uses the same EMBEDDING_OPENAI_API_KEY above
LLM_MODEL=gpt-4o-mini


# ── Alternative Detection ─────────────────────────────────
# On every store (L2-L4), Synatyx compares the new memory against existing
# ones to find items serving the same purpose (see docs/alternatives.md).
RELATION_DETECT_ENABLED=true
# similarity >= this -> alternative_to edge created automatically
RELATION_AUTOLINK_THRESHOLD=0.92
# this <= similarity < autolink -> returned as a suggestion to confirm
RELATION_SUGGEST_THRESHOLD=0.80
# max detections returned per stored item
RELATION_DETECT_LIMIT=5

# ── Type-aware staleness (GC decay per fact type) ─────────────────────────────
# Items tagged with metadata.fact_type get their GC TTL scaled by these
# multipliers. JSON object; unknown types default to 1.0.
GC_FACT_TYPE_MULTIPLIERS={"file-location": 0.3, "config": 0.7, "architecture": 1.5, "preference": 3.0}

# ── Memory consolidation (background L2 → L3 merge) ──────────────────────────
# Runs after each GC pass (and on demand via the context_consolidate tool).
CONSOLIDATION_ENABLED=true
# Cosine similarity two L2 items must reach to be clustered together
CONSOLIDATION_SIMILARITY_THRESHOLD=0.83
# Clusters smaller than this are left untouched
CONSOLIDATION_MIN_CLUSTER_SIZE=3
# Safety valve: max merges per pass across all collections
CONSOLIDATION_MAX_MERGES_PER_RUN=20

# ── Automatic session capture (scripts/capture_session.py hook) ──────────────
# Used by the Claude Code SessionEnd hook, not by the server itself:
#   SYNATYX_URL=http://localhost:9000
#   SYNATYX_AUTH_KEY=<same as AUTH_ADMIN_KEY>
#   SYNATYX_USER_ID=<memory user id, defaults to OS username>
